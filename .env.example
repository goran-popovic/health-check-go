# How often to run checks, in seconds
CHECK_INTERVAL_SECONDS=30

# Comma-separated list of targets to monitor.
# Format: Name=URL,Name=URL,...
TARGETS=Google=https://www.google.com,GitHub=https://github.com

# Path to the log file. Results are written here AND to the terminal.
# The file is created automatically if it doesn't exist.
LOG_FILE=health-check.log

# Port for the HTTP status dashboard (http://localhost:8080/status).
HTTP_PORT=8080

# Webhook URL for down alerts. Leave empty to disable notifications.
# Use https://webhook.site to get a free test URL.
# Works with Slack, Discord, or any service that accepts a JSON POST.
WEBHOOK_URL=
